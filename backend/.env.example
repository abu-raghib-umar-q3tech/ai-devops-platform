PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/ai

# Auth
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# OpenAI (set DEMO_MODE=true to skip API and use rule-based smartFallback only)
DEMO_MODE=false
OPENAI_API_KEY=replace_me_with_openai_key
OPENAI_MODEL=gpt-4o-mini

